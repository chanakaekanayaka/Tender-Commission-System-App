# Server (optional — Next.js defaults to port 3000)
NODE_ENV=development
# PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/tender-commission-db

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google Gemini (tender document OCR / data extraction)
GEMINI_API_KEY=replace_with_your_gemini_api_key

# n8n webhook (overdue job order follow-ups)
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/job-order-followup
