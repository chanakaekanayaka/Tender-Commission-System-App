# Server (optional — Next.js defaults to port 3000)
NODE_ENV=development
# PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/tender-commission-db

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# AWS (Price Schedule document scan — S3 + Textract)
# No access keys here on purpose: locally the SDK picks up `aws configure` credentials
# automatically; in production it uses the Amplify Hosting SSR compute role. AWS_REGION is
# provided automatically too (by the AWS CLI config locally, by Lambda at runtime in prod).
S3_BUCKET_NAME=replace_with_your_s3_bucket_name
