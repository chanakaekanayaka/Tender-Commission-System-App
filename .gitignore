# Unified Next.js monorepo — single app, single .gitignore.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# build output
.next/
out/
dist/
build/

# testing
coverage/

# env files (never commit real secrets — see .env.example)
.env
.env.*
!.env.example

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/

# misc
*.pem
.vercel
*.tsbuildinfo
next-env.d.ts
